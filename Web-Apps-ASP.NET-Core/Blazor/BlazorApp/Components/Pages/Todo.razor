@page "/todo"
@rendermode InteractiveServer

<PageTitle>Todo List</PageTitle>

<div class="container mt-4">
    <h1>My Todo List</h1>
    <p class="text-muted">Active tasks: <strong>@todos.Count(todo => !todo.IsDone)</strong></p>

    <div class="input-group mb-3">
        <input type="text" class="form-control" @bind="newTodo" @onkeyup="HandleKeyPress" placeholder="Add a new task..." />
        <button class="btn btn-primary" @onclick="AddTodo">Add</button>
    </div>

    @if (todos.Count == 0)
    {
        <p class="alert alert-info">No tasks yet. Add one to get started!</p>
    }
    else
    {
        <div class="list-group">
            @foreach (var item in todos)
            {
                <div class="list-group-item d-flex justify-content-between align-items-center">
                    <div class="flex-grow-1">
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" id="todo_@item.Id" @bind="item.IsDone" />
                            <label class="form-check-label @(item.IsDone ? "text-decoration-line-through text-muted" : "")" for="todo_@item.Id">
                                @item.Title
                            </label>
                        </div>
                    </div>
                    <button class="btn btn-sm btn-danger" @onclick="() => DeleteTodo(item.Id)">Delete</button>
                </div>
            }
        </div>
    }

    @if (todos.Count > 0)
    {
        <p class="mt-3 text-center">
            <button class="btn btn-warning btn-sm" @onclick="ClearCompleted">Clear Completed</button>
        </p>
    }
</div>

@code {
    private List<TodoItem> todos = new List<TodoItem>();
    int nextId = 1;
    string newTodo = string.Empty;

    void AddTodo()
    {
        if (!string.IsNullOrWhiteSpace(newTodo))
        {
            todos.Add(new TodoItem
            {
                Id = nextId++,
                Title = newTodo,
                CreatedAt = DateTime.Now
            });
            newTodo = string.Empty;
        }
    }

    void DeleteTodo(int id)
    {
        todos.RemoveAll(t => t.Id == id);
    }

    void ClearCompleted()
    {
        todos.RemoveAll(t => t.IsDone);
    }

    void HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            AddTodo();
        }
    }
}
