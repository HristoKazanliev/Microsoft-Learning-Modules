@page "/todo"
@rendermode InteractiveServer

<h3>Todo (@todos.Count(todo => !todo.IsDone))</h3>

<ul>
    @foreach (var item in todos)
    {
        <li>
            <input type="checkbox" @bind="item.IsDone" />
            <input @bind ="item.Title" />
        </li>
    }
</ul>

<input @bind="newTodo"  />
<button class="btn btn-primary" @onclick="AddTodo">Add</button><br />

@if (todos.Count > 0)
{
    <button class="btn btn-danger" @onclick="ClearCompleted">Clear Completed</button>
}

@code {
    private List<TodoItem> todos = new List<TodoItem>();
    int nextId = 1;
    string newTodo = string.Empty;

    void AddTodo()
    {
        if (!string.IsNullOrWhiteSpace(newTodo))
        {
            todos.Add(new TodoItem 
            { 
                Id = nextId++,
                Title = newTodo,
                CreatedAt = DateTime.Now
            });
            newTodo = string.Empty;
        }    
    }

    void DeleteTodo(int id)
    {
        todos.RemoveAll(t => t.Id == id);
    }

    void ClearCompleted()
    {
        todos.RemoveAll(t => t.IsDone);
    }

}
